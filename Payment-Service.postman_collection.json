{
  "info": {
    "_postman_id": "payment-service-collection",
    "name": "Payment Service API",
    "description": "Collection of API calls for the Payment Service built with Spring Boot + Spring Data JPA",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment - Credit Card",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 250.75,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"CREDIT_CARD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Create a new payment using a credit card"
          },
          "response": []
        },
        {
          "name": "Create Payment - PayPal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 500.00,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"PAYPAL\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Create a new payment using PayPal"
          },
          "response": []
        },
        {
          "name": "Create Payment - Bank Transfer (EUR)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 1200.00,\n  \"currency\": \"EUR\",\n  \"paymentMethod\": \"BANK_TRANSFER\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Create a new payment using a bank transfer in EUR"
          },
          "response": []
        },
        {
          "name": "Create Payment - Debit Card (GBP)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 75.50,\n  \"currency\": \"GBP\",\n  \"paymentMethod\": \"DEBIT_CARD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Create a new payment using a debit card in GBP"
          },
          "response": []
        },
        {
          "name": "Create Payment - Validation Error (negative amount)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": -50.00,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"CREDIT_CARD\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Should return 400 Bad Request due to negative amount"
          },
          "response": []
        },
        {
          "name": "Create Payment - Validation Error (missing fields)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100.00\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Should return 400 Bad Request due to missing required fields"
          },
          "response": []
        },
        {
          "name": "Get All Payments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments"]
            },
            "description": "Fetch all payments stored in the database"
          },
          "response": []
        },
        {
          "name": "Get Payment By ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/:id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "REPLACE_WITH_PAYMENT_ID",
                  "description": "Replace this with the ID returned from the Create Payment request"
                }
              ]
            },
            "description": "Fetch a specific payment by its UUID. Replace :id with the actual ID from a Create Payment response."
          },
          "response": []
        },
        {
          "name": "Get Payment By ID - Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Should return 404 Not Found for a non-existent payment ID"
          },
          "response": []
        },
        {
          "name": "Health Check (Actuator)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/actuator/health",
              "host": ["{{baseUrl}}"],
              "path": ["actuator", "health"]
            },
            "description": "Check the health status of the application"
          },
          "response": []
        }
      ]
    }
  ]
}
